<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="semubot_head" params="parent xyz:='0 0 0' rpy:='0 0 0'">
    <link name="head_base_link">
      <visual>
        <geometry>
          <mesh filename="package://semubot_description/meshes/visual/head_base.stl" scale="1 1 1"/>
        </geometry>
        <material name="semubot_white"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.09" length="0.12"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.6"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.006" ixy="0.0" ixz="0.0" iyy="0.006" iyz="0.0" izz="0.006"/>
      </inertial>
    </link>

    <joint name="head_yaw_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="head_base_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <axis xyz="0 0 1"/>
      <limit effort="2.0" velocity="0.5"/>
    </joint>

    <link name="head_scalp_link">
      <visual>
        <geometry>
          <mesh filename="package://semubot_description/meshes/visual/head_scalp.stl" scale="1 1 1"/>
        </geometry>
        <material name="semubot_cyan"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="0.12"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.25"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.003"/>
      </inertial>
    </link>

    <joint name="head_scalp_joint" type="fixed">
      <parent link="head_base_link"/>
      <child link="head_scalp_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="head_screen_link">
      <visual>
        <geometry>
          <mesh filename="package://semubot_description/meshes/visual/head_screen.stl" scale="1 1 1"/>
        </geometry>
        <material name="semubot_black"/>
      </visual>
      <collision>
        <geometry>
          <box size="0.10 0.02 0.08"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.15"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.0015" ixy="0.0" ixz="0.0" iyy="0.0015" iyz="0.0" izz="0.0015"/>
      </inertial>
    </link>

    <joint name="head_screen_joint" type="fixed">
      <parent link="head_base_link"/>
      <child link="head_screen_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
  </xacro:macro>
</robot>
