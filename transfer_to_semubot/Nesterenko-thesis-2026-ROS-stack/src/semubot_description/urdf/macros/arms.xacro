<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="semubot_arms" params="parent">
    <link name="left_arm_link">
      <visual>
        <geometry>
          <mesh filename="package://semubot_description/meshes/visual/left_hand.stl" scale="1 1 1"/>
        </geometry>
        <material name="semubot_white"/>
      </visual>
      <collision>
        <origin xyz="0 0.05 -0.10" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.03" length="0.30"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.5"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <joint name="left_arm_joint" type="revolute">
      <parent link="${parent}"/>
      <child link="left_arm_link"/>
      <origin xyz="0 0.175 0.555" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.2" upper="1.2" effort="5.0" velocity="0.5"/>
    </joint>

    <link name="right_arm_link">
      <visual>
        <geometry>
          <mesh filename="package://semubot_description/meshes/visual/right_hand.stl" scale="1 1 1"/>
        </geometry>
        <material name="semubot_white"/>
      </visual>
      <collision>
        <origin xyz="0 -0.05 -0.10" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.03" length="0.30"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.5"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <joint name="right_arm_joint" type="revolute">
      <parent link="${parent}"/>
      <child link="right_arm_link"/>
      <origin xyz="0 -0.175 0.555" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.2" upper="1.2" effort="5.0" velocity="0.5"/>
    </joint>
  </xacro:macro>
</robot>
