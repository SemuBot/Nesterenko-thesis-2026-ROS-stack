<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="semubot_base" params="">
    <!-- Ground-projected body frame for navigation and footprint reasoning. -->
    <link name="base_footprint"/>

    <!-- Main mobile-base body frame. -->
    <link name="base_link">
      <visual>
        <origin xyz="0 0 0.04" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://semubot_description/meshes/visual/movement_frame.stl" scale="1 1 1"/>
        </geometry>
        <material name="semubot_white"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.10" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.28" length="0.20"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.10" rpy="0 0 0"/>
        <mass value="8.0"/>
        <inertia ixx="0.200" ixy="0.0" ixz="0.0" iyy="0.200" iyz="0.0" izz="0.200"/>
      </inertial>
    </link>

    <joint name="base_footprint_to_base_link" type="fixed">
      <parent link="base_footprint"/>
      <child link="base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Omni-ball visual links. Collision is simplified via spheres for performance. -->
    <link name="omni_ball_1">
      <visual>
        <geometry>
          <mesh filename="package://semubot_description/meshes/visual/omni_ball.stl" scale="1 1 1"/>
        </geometry>
        <material name="semubot_white"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="0.06"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>
    <joint name="omni_ball_1_joint" type="continuous">
      <parent link="base_link"/>
      <child link="omni_ball_1"/>
      <!-- Lowered Z to keep visual omni-balls below the movement frame. -->
      <origin xyz="0.16 0.265 -0.06" rpy="0 0 2.0944"/>
      <axis xyz="1 0 0"/>
      <limit effort="50" velocity="1.0"/>
    </joint>

    <link name="omni_ball_2">
      <visual>
        <geometry>
          <mesh filename="package://semubot_description/meshes/visual/omni_ball.stl" scale="1 1 1"/>
        </geometry>
        <material name="semubot_white"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="0.06"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>
    <joint name="omni_ball_2_joint" type="continuous">
      <parent link="base_link"/>
      <child link="omni_ball_2"/>
      <origin xyz="0.16 -0.265 -0.06" rpy="0 0 -2.0944"/>
      <axis xyz="1 0 0"/>
      <limit effort="50" velocity="1.0"/>
    </joint>

    <link name="omni_ball_3">
      <visual>
        <geometry>
          <mesh filename="package://semubot_description/meshes/visual/omni_ball.stl" scale="1 1 1"/>
        </geometry>
        <material name="semubot_white"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="0.06"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>
    <joint name="omni_ball_3_joint" type="continuous">
      <parent link="base_link"/>
      <child link="omni_ball_3"/>
      <origin xyz="-0.3 0 -0.06" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit effort="50" velocity="1.0"/>
    </joint>
  </xacro:macro>
</robot>
